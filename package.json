{
  "name": "x-prober",
  "description": "A PHP probe",
  "license": "GPL-3",
  "homepage": "https://github.com/kmvan/x-prober",
  "type": "module",
  "scripts": {
    "lang": "node ./tools/lang-builder.mjs",
    "dev": "vite --config ./dev.vite.config.mjs",
    "dev:php": "bash ./php-dev.sh",
    "build": "vite build --config ./prod.vite.config.mjs",
    "build:php": "bash ./php-build.sh",
    "build:php-debug": "php ./Make.php build debug && echo '\nPlease access via http://localhost:8001/prober.php' && PHP_CLI_SERVER_WORKERS=4 php -S localhost:8001 -t dist",
    "php-cs-fixer-54": "php-cs-fixer fix ./src --config=.php-cs-fixer54"
  },
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "copy-to-clipboard": "^4.0.2",
    "immer": "^11.1.11",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "css-loader": "^7.1.4",
    "deep-sort-object": "^1.0.2",
    "gettext-parser": "^9.1.1",
    "mini-css-extract-plugin": "^2.10.2",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "style-loader": "^4.0.0",
    "typescript": "^7.0.2",
    "ultracite": "^7.9.3",
    "update-browserslist-db": "^1.2.3",
    "vite": "^8.1.4",
    "vite-plugin-dts": "^5.0.3"
  }
}